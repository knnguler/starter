{
    "name": "knnguler/starter",
    "description": "Custom Starter Kit Package with Livewire 4 and TailwindCSS 4",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Local\\StarterKit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Local\\StarterKit\\StarterKitServiceProvider"
            ]
        }
    }
}
